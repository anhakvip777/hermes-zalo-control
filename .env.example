# ── Environment Config ──────────────────────────────────────────
# Copy this file to packages/backend/.env and fill in real values.
# NEVER commit .env with real secrets.

NODE_ENV=development
PORT=3002
HOST=127.0.0.1
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Database (SQLite for dev)
DATABASE_URL="file:./dev.db"
REDIS_URL=

# Zalo Session
ZALO_SESSION_DIR=./zalo-session
ZALO_DRY_RUN=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3002

# Security — GENERATE REAL SECRETS for production
JWT_SECRET=<openssl rand -hex 32>
COOKIE_SECRET=<openssl rand -hex 32>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<strong unique password>

LOG_LEVEL=info

# Rate limiting
ZALO_RATE_LIMIT_PER_MINUTE=10
ZALO_RATE_LIMIT_GLOBAL_PER_MINUTE=60
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# ── Auto Reply Pipeline ─────────────────────────────────────────
ZALO_AUTO_REPLY_ENABLED=false
ZALO_AUTO_REPLY_DRY_RUN=true
ZALO_AUTO_REPLY_ALLOWED_THREADS=
ZALO_AUTO_REPLY_COOLDOWN_SECONDS=10

# ── Hermes Chat Adapter ─────────────────────────────────────────
# mock = echo (safe, no external calls)
# real = call Hermes via HTTP or CLI
HERMES_CHAT_ADAPTER=mock

# http = POST to HERMES_CHAT_ENDPOINT
# cli  = spawn Hermes CLI binary
HERMES_CHAT_MODE=http

# HTTP mode endpoint (only used when HERMES_CHAT_MODE=http)
HERMES_CHAT_ENDPOINT=

# CLI mode binary path (only used when HERMES_CHAT_MODE=cli)
HERMES_CHAT_CLI_BIN=/path/to/hermes

# Timeouts (ms)
HERMES_CHAT_TIMEOUT_MS=30000
HERMES_CHAT_CLI_TIMEOUT_MS=60000

# Confidence threshold — skip real send if confidence below this
HERMES_CHAT_MIN_CONFIDENCE=0.5
