# =============================================================================
# Hermes Zalo Control Center — Environment Variables
# Copy this to .env and fill in your values.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── Admin Auth ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme  # ⚠️ CHANGE THIS

# ── JWT & Cookies ─────────────────────────────────────────────────────
JWT_SECRET=changeme       # ⚠️ CHANGE THIS
COOKIE_SECRET=changeme    # ⚠️ CHANGE THIS

# ── AI Provider (ChiaseGPU) ───────────────────────────────────────────
CHIASEGPU_API_KEY=changeme  # ⚠️ CHANGE THIS
CHIASEGPU_BASE_URL=https://llm.chiasegpu.vn/v1

# ── Zalo Auto Reply ───────────────────────────────────────────────────
ZALO_AUTO_REPLY_ENABLED=false
ZALO_AUTO_REPLY_DRY_RUN=true         # Safe default: dry-run
ZALO_AUTO_REPLY_ALLOWED_THREADS=
ZALO_AUTO_REPLY_COOLDOWN_SECONDS=10
ZALO_DRY_RUN=true

# ── Zalo Vision (OCR) ─────────────────────────────────────────────────
ZALO_VISION_ENABLED=false
ZALO_VISION_MODEL=gpt-5.4

# ── Zalo Voice (TTS) ──────────────────────────────────────────────────
ZALO_VOICE_ENABLED=false
# ALLOW_UNSTABLE_VOICE=true  # Only set if you accept native voice instability

# ── Zalo Session ──────────────────────────────────────────────────────
ZALO_SESSION_DIR=./zalo-session

# ── Security ──────────────────────────────────────────────────────────
# STRICT_CONFIG_CHECK=true   # Block startup if config has errors
# ALLOW_DB_RESET=true        # Only enable when you need to reset DB
ALLOW_MULTIPLE_BACKEND_INSTANCES=false

# ── Frontend ──────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
