{
  "name": "@hermes/backend",
  "version": "0.1.0",
  "description": "Hermes Zalo Control Center backend — Fastify API server, Prisma ORM, BullMQ worker",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx src/workers/index.ts",
    "worker:documents": "tsx src/workers/document-worker.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push:safe": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/db-guard.mjs --before-db-push && prisma db push",
    "db:reset:safe": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/db-guard.mjs --before-reset && prisma db push --force-reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:guard": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/db-guard.mjs --status",
    "db:guard:backup": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/db-guard.mjs --backup",
    "db:guard:status": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/db-guard.mjs --status",
    "backup:create": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/backup-restore.mjs create",
    "backup:list": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/backup-restore.mjs list",
    "backup:verify": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/backup-restore.mjs verify",
    "backup:restore": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/backup-restore.mjs restore",
    "restart:safe": "/home/anhakvip777/.nvm/versions/node/v22.23.0/bin/node scripts/backup-restore.mjs create --reason pre-restart",
    "config:check": "tsx src/config-consistency.ts",
    "config:check:strict": "STRICT_CONFIG_CHECK=true tsx src/config-consistency.ts",
    "secret:audit": "node scripts/secret-audit.mjs",
    "secret:audit:strict": "node scripts/secret-audit.mjs --strict"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@hermes/shared": "*",
    "@prisma/client": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "node-cron": "^3.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zca-js": "^2.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
