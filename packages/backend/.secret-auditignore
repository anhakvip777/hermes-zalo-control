# Secret Audit Allowlist
# Files/paths matching these patterns are excluded from secret scanning.
# One pattern per line. Supports regex.
#
# Example patterns:
#   test/.*
#   docs/example-secret\.md
#   .*\.test\.ts

# ── Test fixtures use fake keys ───────────────────────────────────────
.*test\.ts
.*\.test\.mjs
scripts/.*\.mjs

# ── Docs may mention example keys ─────────────────────────────────────
docs/.*
CLAUDE\.md
PLAN\.md
README\.md

# ── Config templates ──────────────────────────────────────────────────
\.env\.example
# .env is the running config — expected to have real secrets (gitignored)
\.env$

# ── Node modules (already skipped by glob, but explicit) ──────────────
node_modules/.*
\.next/.*
dist/.*
coverage/.*
